{
  "_description": "5-Year Capital Appreciation Model - Bear/Base/Bull Scenarios",
  "_provenance": {
    "source": "Land Registry HPI + Oxford Economics + Internal Analysis",
    "methodology": "Multi-scenario model using postcode-level historical volatility and area momentum",
    "last_refreshed": "2026-03-30"
  },
  "_tasks_completed": ["DAT-151", "DAT-152"],

  "scenario_definitions": {
    "bear": {
      "probability": 15,
      "annual_return": -1.5,
      "five_year_total": -7.3,
      "trigger": "Recession, unemployment spike, BoE rates >5%"
    },
    "base": {
      "probability": 60,
      "annual_return": 2.0,
      "five_year_total": 10.4,
      "trigger": "Soft landing, stable rates, moderate growth"
    },
    "bull": {
      "probability": 25,
      "annual_return": 4.5,
      "five_year_total": 24.6,
      "trigger": "Rate cuts, supply shock, foreign demand surge"
    }
  },

  "property_adjustments": {
    "lease_risk": {
      "description": "Lease length impacts appreciation - short leases hard to sell",
      "under_80_years": -0.5,
      "80_to_90_years": -0.3,
      "90_to_125_years": 0,
      "over_125_years": 0.1
    },
    "epc_rating": {
      "description": "Energy efficiency increasingly impacts value and saleability",
      "rating_a_to_b": 0.2,
      "rating_c": 0,
      "rating_d": -0.1,
      "rating_e_to_g": -0.3
    },
    "floor_level": {
      "description": "Ground floor premium/s discount",
      "ground_floor": -0.1,
      "standard_floor": 0,
      "upper_floor_with_lift": 0.1,
      "penthouse": 0.3
    },
    "service_charge": {
      "description": "High service charges reduce appreciation potential",
      "high_charge_penalty": -0.2,
      "threshold_annual": 6000
    }
  },

  "postcode_volatility": {
    "NW3": {
      "annual_volatility": 3.2,
      "standard_deviation": 4.1,
      "correlation_with_london": 0.85
    },
    "NW6": {
      "annual_volatility": 4.1,
      "standard_deviation": 5.2,
      "correlation_with_london": 0.82
    },
    "N1": {
      "annual_volatility": 3.8,
      "standard_deviation": 4.8,
      "correlation_with_london": 0.88
    },
    "N7": {
      "annual_volatility": 4.5,
      "standard_deviation": 5.8,
      "correlation_with_london": 0.80
    },
    "W2": {
      "annual_volatility": 2.8,
      "standard_deviation": 3.5,
      "correlation_with_london": 0.90
    },
    "SW3": {
      "annual_volatility": 2.5,
      "standard_deviation": 3.2,
      "correlation_with_london": 0.92
    },
    "SW10": {
      "annual_volatility": 3.0,
      "standard_deviation": 3.8,
      "correlation_with_london": 0.88
    }
  },

  "rental_yield_estimates": {
    "_description": "Gross rental yield by area for investment analysis",
    "NW3": { "gross_yield": 3.2, "net_yield": 2.6 },
    "NW6": { "gross_yield": 3.8, "net_yield": 3.1 },
    "N1": { "gross_yield": 3.5, "net_yield": 2.9 },
    "N7": { "gross_yield": 4.1, "net_yield": 3.4 },
    "W2": { "gross_yield": 3.0, "net_yield": 2.4 },
    "SW3": { "gross_yield": 2.8, "net_yield": 2.2 },
    "SW10": { "gross_yield": 3.0, "net_yield": 2.5 }
  },

  "boe_rate_path_fan": {
    "_description": "Forward rate path probabilities from SONIA futures",
    "scenarios": [
      { "q": "2026-Q3", "bear": 4.50, "base": 3.75, "bull": 3.50 },
      { "q": "2026-Q4", "bear": 4.75, "base": 3.65, "bull": 3.25 },
      { "q": "2027-Q1", "bear": 5.00, "base": 3.50, "bull": 3.00 },
      { "q": "2027-Q2", "bear": 5.00, "base": 3.50, "bull": 2.75 }
    ]
  },

  "monte_carlo_parameters": {
    "iterations": 10000,
    "time_horizon_years": 5,
    "confidence_intervals": {
      "p10": "Bear case threshold",
      "p50": "Base case / median",
      "p90": "Bull case threshold"
    },
    "random_walk_parameters": {
      "drift": 0.02,
      "volatility_range": [0.025, 0.055],
      "correlation_matrix": "London-wide HPI correlation by postcode"
    }
  },

  "appreciation_calculation": {
    "_description": "Appreciation: future_value = current_price × (1 + scenario_return)^years + property_adjustments",
    "_provenance": {
      "source": "Land Registry HPI + Internal Analysis",
      "source_url": "https://landregistry.data.gov.uk/",
      "methodology": "Multi-scenario compound appreciation model. Scenario returns compound annually. Property adjustments are additive.",
      "last_refreshed": "2026-04-01"
    },
    "scenario_definitions": {
      "bear": { "five_year_total_pct": -7.3, "annual_avg_pct": -1.5 },
      "base": { "five_year_total_pct": 10.4, "annual_avg_pct": 2.0 },
      "bull": { "five_year_total_pct": 24.6, "annual_avg_pct": 4.5 }
    },
    "example_600k_property": {
      "current_price_gbp": 600000,
      "bear_5yr_gbp": 553200,
      "base_5yr_gbp": 663900,
      "bull_5yr_gbp": 752100
    }
  }
}
