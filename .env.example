# FlareSolverr — Cloudflare bypass proxy (local network)
# Used by: scripts/scrape_visuals.js
# Connection: HTTP (not HTTPS) on port 8191
# Ask the owner for the local network URL and session name.
# Copy this file to .env.local with your actual values:
#   cp .env.example .env.local
FLARESOLVR_URL=http://<your-local-flaresolverr-host>:8191
FLARESOLVR_SESSION=propSearch
FLARESOLVR_TIMEOUT=60

# Vercel deployment (managed by Vercel CLI — do not commit real tokens)
# VERCEL_OIDC_TOKEN=...
